# =========================================================================
# CalTrack AWS Deployment Config - Environment Template
# =========================================================================

# AWS Authentication & Region
# Specify your target AWS Region and Account ID
AWS_DEFAULT_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Optional IAM Role to assume (e.g. for CI/CD OIDC authentication or local roles)
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/GitHubActionsDeployRole

# ECR Container Registry settings
# Registry URL defaults to "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com"
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
ECR_REPOSITORY=caltrack-api
IMAGE_TAG=latest

# ECS Fargate Target Configuration
ECS_CLUSTER=caltrack-prod-cluster
ECS_SERVICE=caltrack-api-service
ECS_TASK_DEFINITION=caltrack-api

# S3 + CloudFront Frontend Configuration
S3_BUCKET_NAME=caltrack-prod-assets
CLOUDFRONT_DISTRIBUTION_ID=E1234567890ABC

# Verification Endpoints
FRONTEND_URL=https://caltrack.yourdomain.com
API_URL=https://caltrack.yourdomain.com/api
