{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "index.ts",
    "agents/**/*.ts",
    "core/**/*.ts",
    "memory/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
