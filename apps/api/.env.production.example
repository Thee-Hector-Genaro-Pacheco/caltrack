# =========================================================================
# CalTrack API - AWS ECS Production Environment Template
# =========================================================================

# Node Environment
NODE_ENV=production

# Application Port (standard ECS container ingress port)
PORT=3001

# Application Target URL (CORS allowed origin matching the CloudFront endpoint)
FRONTEND_URL=https://caltrack.yourdomain.com

# Relational Database Connection (AWS RDS PostgreSQL)
# Recommend injecting database credentials via AWS Secrets Manager.
# Pattern: postgresql://[USER]:[PASSWORD]@[RDS_ENDPOINT]:5432/[DB_NAME]?schema=public
DATABASE_URL=postgresql://postgres:secure-rds-password@rds-instance-dns-address.us-east-1.rds.amazonaws.com:5432/caltrack?schema=public

# Cryptographically secure random JWT key for signing session tokens
# DO NOT leave this to defaults or commit secrets.
JWT_SECRET=use-a-secure-random-64-character-hex-string
