datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum InstrumentStatus {
  ACTIVE
  CALIBRATION_DUE
  OVERDUE
  INACTIVE
}

model Instrument {
  id                  String              @id @default(uuid())
  tagNumber           String              @unique
  instrumentType      String
  manufacturer        String
  model               String
  rangeMin            Float
  rangeMax            Float
  engineeringUnits    String
  signalType          String
  location            String
  status              InstrumentStatus    @default(ACTIVE)
  maxPermissibleError Float               @default(0.5) // Tolerance % of Span (e.g. 0.5%)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  calibrations        CalibrationRecord[]
  
  processAreaId       String?
  processArea         ProcessArea?        @relation(fields: [processAreaId], references: [id], onDelete: SetNull)
  controlLoopId       String?
  controlLoop         ControlLoop?        @relation(fields: [controlLoopId], references: [id], onDelete: SetNull)

  calibrationIntervalMonths Int           @default(12)
  lastCalibrationDate       DateTime?
  nextCalibrationDueDate    DateTime?
  workOrders                WorkOrder[]
  documents                 Documentation[] @relation("InstrumentDocumentation")
}

model ProcessArea {
  id           String        @id @default(uuid())
  areaCode     String        @unique
  name         String
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  controlLoops ControlLoop[]
  instruments  Instrument[]
}

model ControlLoop {
  id            String       @id @default(uuid())
  loopNumber    String       // e.g. "101" or "215"
  loopTag       String       @unique // e.g. "PT-101 Control Loop"
  description   String?
  pidReference  String?
  processAreaId String
  processArea   ProcessArea  @relation(fields: [processAreaId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  instruments   Instrument[]
}

enum CalibrationStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum SignerRole {
  TECHNICIAN
  SUPERVISOR
  QA
}

enum SignatureMeaning {
  SUBMITTED
  APPROVED
  REJECTED
}

model CalibrationRecord {
  id              String                 @id @default(uuid())
  instrumentId    String
  instrument      Instrument             @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  calibrationDate DateTime
  technicianName  String
  asFound         Float?
  asLeft          Float?
  passFail        Boolean
  notes           String?
  createdAt       DateTime               @default(now())
  testPoints      CalibrationTestPoint[]
  status          CalibrationStatus      @default(DRAFT)
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  signatures      Signature[]
  referenceStandards CalibrationReferenceStandard[]
}

model Signature {
  id                  String            @id @default(uuid())
  calibrationRecordId String
  calibrationRecord   CalibrationRecord @relation(fields: [calibrationRecordId], references: [id], onDelete: Cascade)
  signerName          String
  signerRole          SignerRole
  meaning             SignatureMeaning
  signatureHash       String
  signedAt            DateTime          @default(now())
}

model CalibrationTestPoint {
  id                  String            @id @default(uuid())
  calibrationRecordId String
  calibrationRecord   CalibrationRecord @relation(fields: [calibrationRecordId], references: [id], onDelete: Cascade)
  targetInput         Float
  expectedOutput      Float
  asFoundOutput       Float
  asLeftOutput        Float
  asFoundError        Float
  asLeftError         Float
  passFail            Boolean
}

model AuditEvent {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String   // CREATE, UPDATE, DELETE
  oldValue   Json?
  newValue   Json?
  changedBy  String   // Technician name or email
  timestamp  DateTime @default(now())
  reason     String?
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model WorkOrder {
  id                 String            @id @default(uuid())
  workOrderNumber    String            @unique
  instrumentId       String
  instrument         Instrument        @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  status             WorkOrderStatus   @default(OPEN)
  priority           WorkOrderPriority @default(MEDIUM)
  assignedTechnician String?
  scheduledDate      DateTime?
  completedDate      DateTime?
  description        String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

enum ReferenceStandardStatus {
  ACTIVE
  DUE_SOON
  EXPIRED
  OUT_OF_SERVICE
}

model ReferenceStandard {
  id                 String                         @id @default(uuid())
  assetTag           String                         @unique
  equipmentType      String
  manufacturer       String
  model              String
  serialNumber       String
  accuracyClass      String
  certificateNumber  String
  lastCalibratedDate DateTime
  calibrationDueDate DateTime
  status             ReferenceStandardStatus        @default(ACTIVE)
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt
  calibrations       CalibrationReferenceStandard[]
}

model CalibrationReferenceStandard {
  id                  String            @id @default(uuid())
  calibrationRecordId String
  calibrationRecord   CalibrationRecord @relation(fields: [calibrationRecordId], references: [id], onDelete: Cascade)
  referenceStandardId String
  referenceStandard   ReferenceStandard @relation(fields: [referenceStandardId], references: [id], onDelete: Restrict)
  usageNotes          String?
}

model Documentation {
  id                String       @id @default(uuid())
  title             String
  description       String?
  documentNumber    String       @unique
  revision          String
  manufacturer      String?
  instrumentType    String?
  equipmentCategory String?
  documentType      String
  tags              String[]
  uploadDate        DateTime     @default(now())
  fileLocation      String
  status            String       @default("ACTIVE")
  
  instruments       Instrument[] @relation("InstrumentDocumentation")
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

enum UserRole {
  ADMINISTRATOR
  SUPERVISOR
  QA_REVIEWER
  TECHNICIAN
  METROLOGY_MANAGER
  DEMO_VIEWER
}

model User {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(TECHNICIAN)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
