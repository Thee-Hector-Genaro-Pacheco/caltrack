# Port the Express API will listen on
PORT=3001

# Node Environment (development or production)
NODE_ENV=development

# PostgreSQL Database Connection URL
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5433/caltrack?schema=public"

# Cross-Origin Resource Sharing (CORS) origin
FRONTEND_URL="http://localhost:5173"

# JWT secret key for signature verification
JWT_SECRET="generate-a-secure-random-secret-key-for-production"
